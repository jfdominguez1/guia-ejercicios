---
import Base from '../layouts/Base.astro';
---

<Base titulo="Ejercicio — Guía de Ejercicios" activa="catalogo">
  <div id="detalle"><p class="ayuda">Cargando…</p></div>
</Base>

<style>
  #detalle :global(.gif) {
    width: 100%;
    max-width: 360px;
    border-radius: var(--radio);
    background: var(--borde);
    display: block;
    margin: 0 auto;
  }
  #detalle :global(ol) { padding-left: 20px; }
  #detalle :global(li) { margin: 6px 0; }
  #detalle :global(.variante-grupo) { margin: 6px 0; font-size: 14px; }
  #detalle :global(.progreso) { color: var(--accion); }
  #detalle :global(.progreso .eyebrow) { color: var(--tinta-suave); }
  #detalle :global(.spark) {
    display: block;
    width: 100%;
    height: 56px;
    margin: 8px 0 4px;
    overflow: visible;
  }
  #detalle :global(.progreso p) { color: var(--tinta); font-weight: 600; margin: 2px 0; }
  #detalle :global(.progreso .ayuda) { color: var(--tinta-suave); font-weight: 400; }
</style>

<script>
  import { variantesDe, ultimaVez } from '../lib/motor';
  import { historialMovimiento, tendencia } from '../lib/progreso';
  import { sparkline } from '../lib/sparkline';
  import { formatearPeso } from '../lib/unidades';
  import { storage } from '../lib/storage';
  import { cargarCatalogoCompleto, urlGif, urlImg, escapar, rutaBase, hoyISO, haceDias } from '../ui/datos';
  import type { Ejercicio, GrupoEquip } from '../lib/tipos';

  const LABEL_GRUPO: Record<string, string> = {
    pesas: 'Pesas', maquina: 'Máquina', banda: 'Banda', cuerpo: 'Cuerpo', pelota: 'Pelota', rodillo: 'Rodillo',
  };

  function lineaUltimaVez(e: Ejercicio): string {
    const registro = ultimaVez(storage.getSesiones(), e.id, e.grupo);
    if (!registro) return 'Nunca lo hiciste';
    const mejor = registro.series[registro.series.length - 1];
    const peso = mejor?.pesoKg !== undefined ? ` · ${mejor.pesoKg} kg` : '';
    const rpe = registro.rpe !== undefined ? ` · RPE ${registro.rpe}` : '';
    return `${haceDias(registro.fecha, hoyISO())} · ${registro.series.length}×${mejor?.reps ?? '?'}${peso}${rpe}`;
  }

  /** Carta con la curva de progreso del ejercicio. Vacía con menos de 2 sesiones. */
  function cartaProgreso(e: Ejercicio, catalogo: Ejercicio[]): string {
    const puntos = historialMovimiento(storage.getSesiones(), e.movimiento, e.grupo, catalogo);
    const t = tendencia(puntos);
    if (!t) return '';
    // La curva usa e1RM si hay peso; a peso corporal, las reps de la serie tope.
    const conPeso = puntos.some((p) => p.pesoTope > 0);
    const valores = puntos.map((p) => (conPeso ? p.e1rm : p.repsTope));
    const spark = sparkline(valores);
    const semanas = Math.max(1, Math.round((Date.parse(t.ultimo.fecha) - Date.parse(t.primero.fecha)) / 604800000));
    const desdeHasta = conPeso
      ? `de ${formatearPeso(t.primero.pesoTope)} a ${formatearPeso(t.ultimo.pesoTope)}`
      : `de ${t.primero.repsTope} a ${t.ultimo.repsTope} reps`;
    const delta = conPeso && t.deltaPesoPct !== 0 ? ` · ${t.deltaPesoPct > 0 ? '+' : ''}${t.deltaPesoPct}%` : '';
    return `
      <div class="carta progreso">
        <span class="eyebrow">Tu progreso</span>
        <svg class="spark" viewBox="0 0 ${spark.ancho} ${spark.alto}" preserveAspectRatio="none" aria-hidden="true">
          <path d="${spark.d}" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke" />
          ${spark.ultimo ? `<circle cx="${spark.ultimo.x}" cy="${spark.ultimo.y}" r="3.5" fill="currentColor" />` : ''}
        </svg>
        <p>${desdeHasta} · ${puntos.length} sesiones · ${semanas} ${semanas === 1 ? 'semana' : 'semanas'}${delta}</p>
        ${conPeso ? '<p class="ayuda">La curva es tu fuerza estimada (reps + peso). El peso mostrado es el real.</p>' : ''}
      </div>`;
  }

  async function pintar() {
    const id = new URLSearchParams(location.search).get('id') ?? '';
    const catalogo = await cargarCatalogoCompleto();
    const e = catalogo.find((x) => x.id === id);
    const caja = document.querySelector('#detalle')!;
    if (!e) {
      caja.innerHTML = `<p class="error">No encontré ese ejercicio.</p>`;
      return;
    }

    const variantes = variantesDe(catalogo, e.movimiento);
    const listaVariantes = (Object.entries(variantes) as Array<[GrupoEquip, Ejercicio[]]>)
      .filter(([grupo, lista]) => lista.length > 0 && grupo !== e.grupo)
      .map(
        ([grupo, lista]) => `
        <div class="variante-grupo"><strong>${LABEL_GRUPO[grupo]}</strong>: ${lista
          .slice(0, 3)
          .map((v) => `<a href="${rutaBase}/ejercicio/?id=${encodeURIComponent(v.id)}">${escapar(v.nombre_es)}</a>`)
          .join(' · ')}</div>`,
      )
      .join('');

    const media = e.custom
      ? `<div class="carta" style="text-align:center">🏋️ Ejercicio tuyo (sin GIF)</div>`
      : e.media === 'img'
        ? `<img class="gif" src="${urlImg(e.id)}" alt="Postura ${escapar(e.nombre_es)}" />`
        : `<img class="gif" src="${urlGif(e.id)}" alt="Demostración de ${escapar(e.nombre_es)}"
           onerror="this.onerror=null;this.src='${urlImg(e.id)}'" />`;

    caja.innerHTML = `
      <button class="boton-silencioso" id="btn-volver" style="padding-left:0">‹ Volver</button>
      <h1 style="margin-top:0">${escapar(e.nombre_es)}</h1>
      <p class="eyebrow">${escapar(e.nombre_en)} · ${e.grupo} · ${e.tipo}</p>
      ${media}
      <div class="carta tipo-${e.tipo}">
        <span class="eyebrow">Músculos</span>
        <p><strong>${escapar(e.musculo)}</strong>${e.secundarios.length ? ` + ${e.secundarios.map(escapar).join(', ')}` : ''}</p>
        ${e.elemento ? `<span class="eyebrow">Necesitás</span><p>🧰 ${escapar(e.elemento)}</p>` : ''}
        <span class="eyebrow">Última vez (${LABEL_GRUPO[e.grupo]})</span>
        <p>${lineaUltimaVez(e)}</p>
      </div>
      ${cartaProgreso(e, catalogo)}
      ${e.pasos.length ? `<h2>Cómo se hace</h2><ol>${e.pasos.map((p) => `<li>${escapar(p)}</li>`).join('')}</ol>` : ''}
      ${listaVariantes ? `<h2>El mismo movimiento con otro equipo</h2>${listaVariantes}` : ''}
    `;
    document.querySelector('#btn-volver')!.addEventListener('click', () => {
      // en la PWA instalada no hay botón atrás del browser
      if (history.length > 1) history.back();
      else window.location.href = `${rutaBase}/catalogo/`;
    });
  }

  pintar();
</script>
