---
import Base from '../layouts/Base.astro';
---

<Base titulo="Rutina — Guía de Ejercicios" activa="rutina">
  <h1>Mi rutina</h1>
  <div id="rutina"><p class="ayuda">Cargando…</p></div>
</Base>

<style>
  #rutina :global(.ejercicio) { padding: 10px 0; border-bottom: 1px solid var(--borde); }
  #rutina :global(.ejercicio:last-of-type) { border-bottom: none; }
  #rutina :global(.ejercicio a) { color: inherit; text-decoration: none; font-weight: 700; }
  #rutina :global(.dosis) { font-size: 14px; color: var(--tinta-suave); }
  #rutina :global(.ultima) { font-size: 13px; color: var(--tinta-suave); }
  #rutina :global(.hoy-chip) {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--accion);
    color: var(--accion-tinta);
    border-radius: 999px;
    padding: 3px 10px;
  }
  #rutina :global(.resultado) {
    display: block;
    width: 100%;
    text-align: left;
    margin: 6px 0;
    padding: 10px 12px;
    font-weight: 600;
  }
  #rutina :global(.resultado .eyebrow) { display: block; }
  #rutina :global(.acciones) { display: flex; gap: 8px; margin-top: 10px; }
  #rutina :global(.acciones .boton-principal) { flex: 2; width: auto; padding: 12px; font-size: 16px; }
  #rutina :global(.panel-ejercicio) { margin-bottom: 0; }
  #rutina :global(.dosis-campos) { display: flex; gap: 8px; }
  #rutina :global(.dosis-campos > div) { flex: 1; }
  #rutina :global(.reemplazo) { display: flex; align-items: center; gap: 8px; }
  #rutina :global(.reemplazo span) { flex: 1; }

</style>

<script>
  import { montarRutina } from '../ui/rutina';
  import { cargarCatalogoCompleto, exigirPerfil, hoyISO } from '../ui/datos';

  const perfil = exigirPerfil();
  if (perfil) {
    cargarCatalogoCompleto().then((catalogo) => {
      montarRutina({
        contenedor: document.querySelector('#rutina') as HTMLElement,
        catalogo,
        perfil,
        hoy: hoyISO,
        confirmar: (mensaje) => window.confirm(mensaje),
      });
    });
  }
</script>
