---
import Base from '../layouts/Base.astro';
---

<Base titulo="Entrenar — Guía de Ejercicios" activa="hoy">
  <div id="wizard"><p class="ayuda">Cargando…</p></div>
</Base>

<style>
  #wizard :global(.gif) {
    width: 100%;
    max-width: 320px;
    border-radius: var(--radio);
    background: var(--borde);
    display: block;
    margin: 8px auto;
  }
  #wizard :global(.progreso) { display: flex; justify-content: space-between; align-items: center; }
  #wizard :global(.serie) {
    display: grid;
    grid-template-columns: 44px 64px 1fr;
    gap: 8px;
    align-items: center;
    margin: 10px 0;
  }
  /* Ejercicios por tiempo: la columna del peso la ocupan la unidad y el reloj. */
  #wizard :global(.serie .tiempo-serie) { display: flex; gap: 8px; align-items: center; }
  #wizard :global(.serie .unidad-serie) {
    font-weight: 700;
    color: var(--tinta-suave);
  }
  #wizard :global(.serie .crono) { flex: 1; padding: 10px 8px; font-size: 14px; }
  #wizard :global(.serie .peso) { display: flex; gap: 6px; align-items: center; }
  #wizard :global(.serie .peso input) { text-align: center; min-width: 0; }
  #wizard :global(.serie .paso) {
    flex: 0 0 44px;
    height: 44px;
    padding: 0;
    font-size: 20px;
    font-weight: 800;
    line-height: 1;
  }
  /* El equivalente en la otra unidad ocupa la fila de abajo, alineado al peso. */
  #wizard :global(.serie .equiv) {
    grid-column: 3;
    font-size: 12px;
    color: var(--tinta-suave);
    text-align: center;
    margin-top: -6px;
  }
  #wizard :global(.cabecera-series) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }
  #wizard :global(.chips.unidad) { gap: 4px; }
  #wizard :global(.chips.unidad .chip) { padding: 5px 12px; font-size: 13px; }
  #wizard :global(.referencia) { padding: 12px 14px; }
  #wizard :global(.dato-referencia) {
    margin: 2px 0 0;
    font-size: 17px;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }
  #wizard :global(.sugerencia) {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px dashed var(--borde);
  }
  #wizard :global(.sugerencia .eyebrow) { color: var(--accion); }
  #wizard :global(.dato-sugerencia) { margin: 4px 0 8px; font-size: 15px; font-weight: 600; }
  #wizard :global(.sugerencia button) { width: 100%; }
  #wizard :global(.serie .check) {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 3px solid var(--borde);
    background: none;
    font-weight: 800;
    padding: 0;
  }
  #wizard :global(.serie.hecha .check) { background: var(--accion); border-color: var(--accion); color: var(--accion-tinta); }
  #wizard :global(.nav) { display: flex; gap: 8px; margin-top: 12px; }
  #wizard :global(.nav button) { flex: 1; }
  #wizard :global(.acciones-ej) { display: flex; gap: 8px; margin-top: 12px; }
  #wizard :global(.acciones-ej button) { flex: 1; font-size: 14px; padding: 10px; }
</style>

<script>
  import { montarEntrenar } from '../ui/entrenar';
  import { cargarCatalogoCompleto, exigirPerfil, hoyISO, rutaBase } from '../ui/datos';

  const perfil = exigirPerfil();
  if (perfil) {
    cargarCatalogoCompleto().then((catalogo) => {
      montarEntrenar({
        contenedor: document.querySelector('#wizard') as HTMLElement,
        catalogo,
        perfil,
        hoy: hoyISO,
        navegar: (ruta) => { window.location.href = `${rutaBase}${ruta}`; },
        confirmar: (mensaje) => window.confirm(mensaje),
      });
    });
  }
</script>
