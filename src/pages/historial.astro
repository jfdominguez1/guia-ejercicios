---
import Base from '../layouts/Base.astro';
---

<Base titulo="Historial — Guía de Ejercicios" activa="historial">
  <h1>Historial</h1>
  <div class="carta" id="calendario"></div>
  <button class="boton-principal" id="btn-cardio">+ Registrar cardio</button>
  <div id="alta-cardio"></div>
  <h2>Sesiones</h2>
  <div id="sesiones"></div>
</Base>

<style>
  #calendario :global(.cabecera) { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  #calendario :global(.grilla) {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    text-align: center;
  }
  #calendario :global(.dow) { font-size: 11px; color: var(--tinta-suave); font-weight: 700; }
  #calendario :global(.dia) {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 13px;
    font-variant-numeric: tabular-nums;
  }
  #calendario :global(.dia.fuerza) { background: var(--fuerza); color: #fff; font-weight: 700; }
  #calendario :global(.dia.cardio) { background: var(--cardio); color: #fff; font-weight: 700; }
  #calendario :global(.dia.elongacion) { background: var(--elongacion); color: #fff; font-weight: 700; }
  #calendario :global(.dia.otro) { background: var(--accion); color: var(--accion-tinta); font-weight: 700; }
  #calendario :global(.dia.hoy) { outline: 2px solid var(--tinta); }
  #calendario :global(.leyenda) { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; font-size: 12px; color: var(--tinta-suave); }
  #calendario :global(.punto) { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 4px; }

  #sesiones :global(details) {
    background: var(--carta);
    border: 1px solid var(--borde);
    border-radius: var(--radio);
    padding: 10px 14px;
    margin: 8px 0;
  }
  #sesiones :global(summary) { font-weight: 700; cursor: pointer; }
  #sesiones :global(.meta) { font-size: 13px; color: var(--tinta-suave); }
  #sesiones :global(.acciones-sesion) { display: flex; gap: 8px; margin-top: 10px; }
  #sesiones :global(.acciones-sesion button) { flex: 1; font-size: 14px; padding: 9px; }
  #sesiones :global(.panel-editar) { margin-top: 10px; border-top: 1px solid var(--borde); padding-top: 10px; }
  #sesiones :global(.panel-editar textarea) { width: 100%; }
  #sesiones :global(.bloque-item) { margin: 8px 0; }
  #sesiones :global(.serie-edit) {
    display: grid;
    grid-template-columns: 64px 1fr 1fr;
    gap: 8px;
    align-items: center;
    margin: 6px 0;
  }
</style>

<script>
  import { storage } from '../lib/storage';
  import { registrarOtra, fechaValidaRetro } from '../lib/registro';
  import { borrarSesion, describirSesion, editarSesion, validarEdicion, type EdicionSesion } from '../lib/historial';
  import { cargarCatalogoCompleto, hoyISO, escapar, exigirPerfil } from '../ui/datos';
  import type { Ejercicio, ItemSesion, Sesion, TipoCardio } from '../lib/tipos';

  const $ = <T extends HTMLElement>(sel: string) => document.querySelector(sel) as T;
  exigirPerfil();

  let catalogo: Ejercicio[] = [];
  let mesVisto = hoyISO().slice(0, 7); // YYYY-MM
  /** Índice (en el array real de sesiones) de la que se está editando. */
  let editando: number | null = null;

  const NOMBRE_TIPO: Record<string, string> = {
    fuerza: 'Fuerza', cardio: 'Cardio', elongacion: 'Elongación', otro: 'Actividad',
  };

  function sesionesDe(fecha: string): Sesion[] {
    return storage.getSesiones().filter((s) => s.fecha === fecha);
  }

  function pintarCalendario() {
    const [anio, mes] = mesVisto.split('-').map(Number) as [number, number];
    const primero = new Date(Date.UTC(anio, mes - 1, 1));
    const diasEnMes = new Date(Date.UTC(anio, mes, 0)).getUTCDate();
    const offset = (primero.getUTCDay() + 6) % 7; // lunes primero
    const nombreMes = primero.toLocaleDateString('es-AR', { month: 'long', year: 'numeric', timeZone: 'UTC' });

    const celdas: string[] = ['L', 'M', 'M', 'J', 'V', 'S', 'D'].map((d) => `<div class="dow">${d}</div>`);
    for (let i = 0; i < offset; i++) celdas.push('<div></div>');
    for (let d = 1; d <= diasEnMes; d++) {
      const fecha = `${mesVisto}-${String(d).padStart(2, '0')}`;
      const del = sesionesDe(fecha);
      const clase = del[0] ? ` ${del[0].tipo}` : '';
      celdas.push(`<div class="dia${clase}${fecha === hoyISO() ? ' hoy' : ''}">${d}</div>`);
    }
    $('#calendario').innerHTML = `
      <div class="cabecera">
        <button class="boton-silencioso" id="mes-antes">‹</button>
        <strong style="text-transform:capitalize">${nombreMes}</strong>
        <button class="boton-silencioso" id="mes-despues">›</button>
      </div>
      <div class="grilla">${celdas.join('')}</div>
      <div class="leyenda">
        <span><span class="punto" style="background:var(--fuerza)"></span>Fuerza</span>
        <span><span class="punto" style="background:var(--cardio)"></span>Cardio</span>
        <span><span class="punto" style="background:var(--elongacion)"></span>Elongación</span>
        <span><span class="punto" style="background:var(--accion)"></span>Otra</span>
      </div>`;
    $('#mes-antes').addEventListener('click', () => moverMes(-1));
    $('#mes-despues').addEventListener('click', () => moverMes(1));
  }

  function moverMes(delta: number) {
    const [anio, mes] = mesVisto.split('-').map(Number) as [number, number];
    const nueva = new Date(Date.UTC(anio, mes - 1 + delta, 1));
    mesVisto = `${nueva.getUTCFullYear()}-${String(nueva.getUTCMonth() + 1).padStart(2, '0')}`;
    pintarCalendario();
  }

  function detalleSesion(s: Sesion): string {
    const lineas: string[] = [];
    if (s.estado === 'otra') lineas.push(`Registrada como "hice otra cosa"${s.duracionMin ? ` · ${s.duracionMin} min` : ''}`);
    if (s.cardio) {
      lineas.push(
        `${s.cardio.tipo} · ${s.cardio.minutos} min${s.cardio.km ? ` · ${s.cardio.km} km` : ''}${s.cardio.sensacion ? ` · ${escapar(s.cardio.sensacion)}` : ''}`,
      );
    }
    if (s.fcPromedio) lineas.push(`🫀 FC promedio ${s.fcPromedio} ppm`);
    if (s.rpe !== undefined) lineas.push(`RPE ${s.rpe}/10`);
    if (s.notas) lineas.push(escapar(s.notas));
    for (const item of s.items ?? []) {
      const info = catalogo.find((e) => e.id === item.ejercicioId);
      const nombre = escapar(info?.nombre_es ?? item.ejercicioId);
      if (item.salteado) {
        lineas.push(`${nombre}: salteado`);
        continue;
      }
      const series = item.series.map((x) => `${x.reps}${x.pesoKg !== undefined ? `×${x.pesoKg}kg` : ''}`).join(' · ');
      const enLugarDe = item.enLugarDe ? catalogo.find((e) => e.id === item.enLugarDe) : undefined;
      const cambio = enLugarDe ? ` <span class="meta">(en lugar de ${escapar(enLugarDe.nombre_es)})</span>` : '';
      lineas.push(`${nombre} (${item.variante}): ${series}${cambio}`);
    }
    return lineas.map((l) => `<p class="meta">${l}</p>`).join('') || '<p class="meta">Sin detalle — hecha es hecha.</p>';
  }

  /** Formulario de edición. Se guarda el índice en el array real, no el visible. */
  function htmlPanelEditar(s: Sesion, idx: number): string {
    const numero = (etiqueta: string, campo: string, valor: number | undefined, extra = '') =>
      `<div style="flex:1"><label>${etiqueta}</label>
        <input type="number" inputmode="numeric" data-campo="${campo}" value="${valor ?? ''}" ${extra} /></div>`;
    const items = (s.items ?? [])
      .map((item, i) => {
        const info = catalogo.find((e) => e.id === item.ejercicioId);
        const series = item.series
          .map(
            (serie, j) => `<div class="serie-edit">
              <span class="meta">Serie ${j + 1}</span>
              <input type="number" inputmode="numeric" data-item="${i}" data-serie="${j}" data-serie-campo="reps" value="${serie.reps}" aria-label="Repeticiones serie ${j + 1}" />
              <input type="number" inputmode="decimal" step="0.5" data-item="${i}" data-serie="${j}" data-serie-campo="peso" value="${serie.pesoKg ?? ''}" placeholder="kg" aria-label="Peso serie ${j + 1}" />
            </div>`,
          )
          .join('');
        return series
          ? `<div class="bloque-item"><strong>${escapar(info?.nombre_es ?? item.ejercicioId)}</strong>${series}</div>`
          : '';
      })
      .join('');

    return `<div class="panel-editar" data-panel="${idx}">
      <label>Fecha</label>
      <input type="date" data-campo="fecha" value="${s.fecha}" max="${hoyISO()}" />
      <div style="display:flex;gap:8px">
        ${numero('RPE (1-10)', 'rpe', s.rpe, 'min="1" max="10"')}
        ${numero('FC prom.', 'fcPromedio', s.fcPromedio, 'min="40" max="220"')}
        ${s.estado === 'otra' ? numero('Minutos', 'duracionMin', s.duracionMin, 'min="1" max="600"') : ''}
      </div>
      ${s.cardio
        ? `<div style="display:flex;gap:8px">
            ${numero('Min. cardio', 'cardioMin', s.cardio.minutos, 'min="1" max="600"')}
            ${numero('Km', 'cardioKm', s.cardio.km, 'min="0" step="0.1"')}
          </div>
          <label>¿Cómo te sentiste?</label>
          <input type="text" data-campo="cardioSensacion" maxlength="80" value="${escapar(s.cardio.sensacion ?? '')}" />`
        : ''}
      ${items ? `<span class="eyebrow" style="display:block;margin-top:10px">Series</span>${items}` : ''}
      <label>Notas</label>
      <textarea data-campo="notas" rows="2" maxlength="500">${escapar(s.notas ?? '')}</textarea>
      <p class="error" data-errores role="alert"></p>
      <div class="acciones-sesion">
        <button class="boton-principal" data-accion="guardar" data-idx="${idx}" style="flex:2">Guardar cambios</button>
        <button data-accion="cancelar">Cancelar</button>
      </div>
    </div>`;
  }

  function pintarSesiones() {
    // Se ordena para mostrar, pero se conserva el índice real para editar/borrar.
    const conIndice = storage.getSesiones().map((sesion, idx) => ({ sesion, idx }));
    const ordenadas = conIndice.sort((a, b) => b.sesion.fecha.localeCompare(a.sesion.fecha));
    $('#sesiones').innerHTML = ordenadas.length
      ? ordenadas
          .slice(0, 60)
          .map(
            ({ sesion: s, idx }) => `<details${editando === idx ? ' open' : ''}>
          <summary>${s.fecha} — ${escapar(s.diaRutina ?? NOMBRE_TIPO[s.tipo] ?? s.tipo)}</summary>
          ${detalleSesion(s)}
          ${editando === idx
            ? htmlPanelEditar(s, idx)
            : `<div class="acciones-sesion">
                <button data-accion="editar" data-idx="${idx}">✎ Editar</button>
                <button data-accion="borrar" data-idx="${idx}">Borrar</button>
              </div>`}
        </details>`,
          )
          .join('')
      : '<div class="carta"><p>Todavía no hay sesiones. La primera se registra desde Hoy con un tap.</p></div>';
    conectarSesiones();
  }

  /** Lee el formulario y arma la edición. Los vacíos quedan en undefined (= borrar campo). */
  function leerEdicion(panel: HTMLElement, s: Sesion): EdicionSesion {
    const texto = (campo: string) =>
      (panel.querySelector(`[data-campo="${campo}"]`) as HTMLInputElement | HTMLTextAreaElement | null)?.value ?? '';
    const numero = (campo: string) => {
      const crudo = texto(campo).trim();
      return crudo === '' ? undefined : Number(crudo);
    };
    const items: ItemSesion[] = (s.items ?? []).map((item, i) => ({
      ...item,
      series: item.series.map((serie, j) => {
        const leer = (campo: string) =>
          (panel.querySelector(`[data-item="${i}"][data-serie="${j}"][data-serie-campo="${campo}"]`) as HTMLInputElement | null)?.value ?? '';
        const peso = leer('peso').trim();
        return {
          reps: Number(leer('reps')) || 0,
          ...(peso === '' ? {} : { pesoKg: Number(peso) }),
        };
      }),
    }));
    const sensacion = texto('cardioSensacion').trim();
    return {
      fecha: texto('fecha'),
      rpe: numero('rpe'),
      fcPromedio: numero('fcPromedio'),
      duracionMin: numero('duracionMin'),
      notas: texto('notas').trim() || undefined,
      ...(s.cardio
        ? { cardio: { minutos: numero('cardioMin') ?? s.cardio.minutos, km: numero('cardioKm'), sensacion: sensacion || undefined } }
        : {}),
      ...(s.items ? { items } : {}),
    };
  }

  function conectarSesiones() {
    $('#sesiones').querySelectorAll('[data-accion]').forEach((boton) =>
      boton.addEventListener('click', (ev) => {
        ev.preventDefault();
        const b = boton as HTMLElement;
        const accion = b.dataset.accion;
        if (accion === 'cancelar') {
          editando = null;
          pintarSesiones();
          return;
        }
        const idx = Number(b.dataset.idx);
        if (accion === 'editar') {
          editando = idx;
          pintarSesiones();
          return;
        }
        if (accion === 'borrar') pedirBorrado(idx);
        if (accion === 'guardar') guardarEdicion(idx);
      }),
    );
  }

  function guardarEdicion(idx: number) {
    const sesiones = storage.getSesiones();
    const actual = sesiones[idx];
    const panel = $('#sesiones').querySelector(`[data-panel="${idx}"]`) as HTMLElement | null;
    if (!actual || !panel) return;
    const edicion = leerEdicion(panel, actual);
    const errores = validarEdicion(edicion, hoyISO());
    const caja = panel.querySelector('[data-errores]') as HTMLElement;
    if (errores.length) {
      caja.textContent = errores.join(' ');
      return;
    }
    if (!confirm(`¿Guardo los cambios en la sesión del ${edicion.fecha}?`)) return;
    storage.setSesiones(editarSesion(sesiones, idx, edicion, hoyISO()));
    editando = null;
    pintarCalendario();
    pintarSesiones();
  }

  /** Borrar es irreversible y no hay backup automático: se pregunta dos veces. */
  function pedirBorrado(idx: number) {
    const sesiones = storage.getSesiones();
    const s = sesiones[idx];
    if (!s) return;
    if (!confirm(`¿Borrar esta sesión?\n\n${describirSesion(s)}`)) return;
    if (!confirm('Última: esto no se puede deshacer y no queda backup.\n\n¿La borro igual?')) return;
    storage.setSesiones(borrarSesion(sesiones, idx));
    editando = null;
    pintarCalendario();
    pintarSesiones();
  }

  function pintarAltaCardio() {
    const tipos: Array<{ v: TipoCardio; l: string }> = [
      { v: 'corrida', l: 'Corrida' },
      { v: 'caminata', l: 'Caminata' },
      { v: 'bicicleta', l: 'Bici' },
      { v: 'eliptica', l: 'Elíptica' },
      { v: 'cinta', l: 'Cinta' },
    ];
    $('#alta-cardio').innerHTML = `<div class="carta tipo-cardio" id="cardio">
      <span class="eyebrow">Registrar cardio</span>
      <div class="chips" style="margin-top:8px">${tipos.map((t) => `<button class="chip" data-tipo="${t.v}">${t.l}</button>`).join('')}</div>
      <label>¿Qué día?</label><input type="date" id="cardio-fecha" value="${hoyISO()}" />
      <label>Minutos</label><input type="number" id="cardio-min" inputmode="numeric" value="30" min="5" max="300" />
      <label>Km <span class="eyebrow">(opcional)</span></label><input type="number" id="cardio-km" inputmode="decimal" step="0.1" min="0" />
      <label>FC promedio <span class="eyebrow">(opcional, ppm)</span></label><input type="number" id="cardio-fc" inputmode="numeric" min="40" max="220" placeholder="De tu banda o reloj" />
      <label>¿Cómo te sentiste? <span class="eyebrow">(opcional)</span></label><input type="text" id="cardio-sensacion" maxlength="80" />
      <p class="error" id="cardio-error" role="alert"></p>
      <button class="boton-principal" id="cardio-guardar" disabled>Guardar cardio ✓</button>
    </div>`;
    const panel = $('#alta-cardio');
    let tipo: TipoCardio | null = null;
    panel.querySelectorAll('[data-tipo]').forEach((chip) =>
      chip.addEventListener('click', () => {
        panel.querySelectorAll('.chip').forEach((c) => c.setAttribute('aria-pressed', 'false'));
        chip.setAttribute('aria-pressed', 'true');
        tipo = (chip as HTMLElement).dataset.tipo as TipoCardio;
        ($('#cardio-guardar') as HTMLButtonElement).disabled = false;
      }),
    );
    $('#cardio-guardar').addEventListener('click', () => {
      const error = $('#cardio-error');
      error.textContent = '';
      const fecha = ($('#cardio-fecha') as HTMLInputElement).value;
      const minutos = Number(($('#cardio-min') as HTMLInputElement).value);
      const km = Number(($('#cardio-km') as HTMLInputElement).value) || undefined;
      const fc = Number(($('#cardio-fc') as HTMLInputElement).value) || undefined;
      const sensacion = ($('#cardio-sensacion') as HTMLInputElement).value.trim() || undefined;
      if (!tipo || !minutos) return;
      if (!fechaValidaRetro(fecha, hoyISO())) {
        error.textContent = 'La fecha tiene que ser de los últimos 7 días.';
        return;
      }
      if (fc !== undefined && (fc < 40 || fc > 220)) {
        error.textContent = 'La FC promedio va entre 40 y 220 ppm.';
        return;
      }
      const base = registrarOtra(tipo === 'caminata' || tipo === 'cinta' ? tipo : 'otro', minutos, fecha);
      storage.agregarSesion({
        ...base,
        tipo: 'cardio',
        estado: 'hecha',
        cardio: { tipo, minutos, ...(km ? { km } : {}), ...(sensacion ? { sensacion } : {}) },
        ...(fc ? { fcPromedio: fc } : {}),
      });
      $('#alta-cardio').innerHTML = '';
      pintarCalendario();
      pintarSesiones();
    });
    document.getElementById('cardio')?.scrollIntoView({ block: 'start' });
  }

  $('#btn-cardio').addEventListener('click', pintarAltaCardio);

  cargarCatalogoCompleto().then((cat) => {
    catalogo = cat;
    pintarCalendario();
    pintarSesiones();
    if (location.hash === '#cardio') pintarAltaCardio();
  });
</script>
