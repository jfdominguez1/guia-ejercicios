---
import Base from '../layouts/Base.astro';
---

<Base titulo="Hoy — Guía de Ejercicios" activa="hoy">
  <div id="hoy"><p class="ayuda">Cargando…</p></div>
</Base>

<style>
  /* La métrica de la semana es EL número de la app: discos de barra. */
  #hoy :global(.semana) { text-align: center; padding: 18px 14px; }
  #hoy :global(.semana .numero) {
    font-size: 44px;
    font-weight: 900;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
  }
  #hoy :global(.discos) { display: flex; justify-content: center; gap: 10px; margin-top: 10px; }
  #hoy :global(.disco) {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 3px solid var(--tinta-suave);
    background: transparent;
  }
  #hoy :global(.disco.lleno) { background: var(--accion); border-color: var(--accion); }

  #hoy :global(.ejercicio) {
    padding: 10px 0;
    border-bottom: 1px solid var(--borde);
  }
  #hoy :global(.ejercicio:last-child) { border-bottom: none; }
  #hoy :global(.ejercicio a) { color: inherit; text-decoration: none; font-weight: 700; }
  #hoy :global(.dosis) { font-size: 14px; color: var(--tinta-suave); }
  #hoy :global(.ultima) { font-size: 13px; color: var(--tinta-suave); }
  #hoy :global(.acciones-extra) { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  #hoy :global(.acciones-extra button) { flex: 1 1 40%; font-size: 14px; padding: 10px; }
  #hoy :global(.retomar) { text-align: center; padding: 28px 16px; }
  #hoy :global(.retomar p) { font-size: 16px; }
  #hoy :global(.rpe-chips) { margin-top: 10px; }
  #hoy :global(.lista-dias) { display: flex; flex-direction: column; gap: 8px; margin: 10px 0; }
  #hoy :global(.opcion-dia) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    text-align: left;
    width: 100%;
    padding: 12px;
  }
  #hoy :global(.opcion-dia.activa) { border-color: var(--accion); }
  #hoy :global(.panel-ejercicio) { margin-bottom: 0; }
  #hoy :global(.dosis-campos) { display: flex; gap: 8px; }
  #hoy :global(.dosis-campos > div) { flex: 1; }
  #hoy :global(.reemplazo) { display: flex; align-items: center; gap: 8px; }
  #hoy :global(.reemplazo span) { flex: 1; }
  #hoy :global(.acciones) { display: flex; gap: 8px; margin-top: 10px; }
  #hoy :global(.acciones .boton-principal) { flex: 2; width: auto; padding: 12px; font-size: 16px; }

</style>

<script>
  import { montarHoy } from '../ui/hoy';
  import { cargarCatalogoCompleto, exigirPerfil, hoyISO, rutaBase } from '../ui/datos';

  const perfil = exigirPerfil();
  if (perfil) {
    cargarCatalogoCompleto().then((catalogo) => {
      montarHoy({
        contenedor: document.querySelector('#hoy') as HTMLElement,
        catalogo,
        perfil,
        hoy: hoyISO,
        confirmar: (mensaje) => window.confirm(mensaje),
        navegar: (ruta) => { window.location.href = `${rutaBase}${ruta}`; },
      });
    });
  }
</script>
