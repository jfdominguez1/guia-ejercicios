---
interface Props {
  titulo?: string;
  activa?: 'hoy' | 'rutina' | 'historial' | 'catalogo' | 'perfil';
}
const { titulo = 'Guía de Ejercicios', activa } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// El ícono no es decoración: a 12px el texto solo obliga a leer para navegar.
// Con figura + palabra la pestaña se reconoce de un vistazo y sudado.
const tabs = [
  { id: 'hoy', label: 'Hoy', href: `${base}/`, icono: '<circle cx="12" cy="12" r="9"/><path d="M8.2 12.4l2.6 2.6 4.9-5.4"/>' },
  { id: 'rutina', label: 'Rutina', href: `${base}/rutina/`, icono: '<path d="M9 6h11M9 12h11M9 18h11"/><circle cx="4.6" cy="6" r="1.4"/><circle cx="4.6" cy="12" r="1.4"/><circle cx="4.6" cy="18" r="1.4"/>' },
  { id: 'historial', label: 'Historial', href: `${base}/historial/`, icono: '<path d="M5 20v-7M12 20V5M19 20v-4"/>' },
  { id: 'catalogo', label: 'Catálogo', href: `${base}/catalogo/`, icono: '<rect x="3.5" y="3.5" width="7" height="7" rx="1.6"/><rect x="13.5" y="3.5" width="7" height="7" rx="1.6"/><rect x="3.5" y="13.5" width="7" height="7" rx="1.6"/><rect x="13.5" y="13.5" width="7" height="7" rx="1.6"/>' },
  { id: 'perfil', label: 'Perfil', href: `${base}/perfil/`, icono: '<circle cx="12" cy="8" r="3.6"/><path d="M4.8 20c0-4 3.2-6.2 7.2-6.2s7.2 2.2 7.2 6.2"/>' },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1b1a16" />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <link rel="icon" type="image/png" href={`${base}/icons/icon-192.png`} />
    <link rel="apple-touch-icon" href={`${base}/icons/apple-touch-icon.png`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Ejercicios" />
    <title>{titulo}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <script is:inline define:vars={{ base }}>
      if ('serviceWorker' in navigator) {
        // Al tocar "Actualizar" el SW nuevo toma el control y esto recarga una sola vez.
        let recargando = false;
        navigator.serviceWorker.addEventListener('controllerchange', () => {
          if (recargando) return;
          recargando = true;
          location.reload();
        });

        const avisarVersionNueva = (worker) => {
          if (document.querySelector('#aviso-version')) return;
          const barra = document.createElement('div');
          barra.id = 'aviso-version';
          barra.innerHTML =
            '<span>Hay una versión nueva</span>' +
            '<button type="button">Actualizar</button>' +
            '<button type="button" class="cerrar" aria-label="Ahora no">✕</button>';
          barra.querySelector('button').addEventListener('click', () => {
            barra.remove();
            worker.postMessage('activar-ya');
          });
          barra.querySelector('.cerrar').addEventListener('click', () => barra.remove());
          document.body.appendChild(barra);
        };

        navigator.serviceWorker
          .register(`${base}/sw.js`)
          .then((registro) => {
            // Ya había una esperando de un deploy anterior.
            if (registro.waiting && navigator.serviceWorker.controller) avisarVersionNueva(registro.waiting);
            registro.addEventListener('updatefound', () => {
              const nuevo = registro.installing;
              if (!nuevo) return;
              nuevo.addEventListener('statechange', () => {
                // Sin controller es la primera instalación: no hay nada que avisar.
                if (nuevo.state === 'installed' && navigator.serviceWorker.controller) avisarVersionNueva(nuevo);
              });
            });
            // Una PWA instalada puede quedar días abierta: se chequea al volver a ella.
            document.addEventListener('visibilitychange', () => {
              if (!document.hidden) registro.update().catch(() => {});
            });
          })
          .catch(() => {});
      }
    </script>
    <nav class="tabs" aria-label="Navegación principal">
      {tabs.map((t) => (
        <a href={t.href} class:list={['tab', { activa: activa === t.id }]} aria-current={activa === t.id ? 'page' : undefined}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={t.icono} />
          <span>{t.label}</span>
        </a>
      ))}
    </nav>
  </body>
</html>

<style is:global>
  /* Tokens — paleta de discos olímpicos: 15kg amarillo (acción), 20kg azul
     (fuerza), 25kg rojo (cardio), 10kg verde (elongación). */
  :root {
    --papel: #f4f3ee;
    --carta: #ffffff;
    --tinta: #23211c;
    --tinta-suave: #6d6a60;
    --borde: #dedbd1;
    --accion: #f2b90d;
    --accion-tinta: #23211c;
    --fuerza: #2458c5;
    --cardio: #c53030;
    --elongacion: #2f8a4c;
    --peligro: #c53030;
    --radio: 14px;
    --fuente: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --papel: #1b1a16;
      --carta: #262521;
      --tinta: #f0eee6;
      --tinta-suave: #a39f92;
      --borde: #3a382f;
      --fuerza: #6f9bee;
      --cardio: #e57373;
      --elongacion: #6fbf8a;
    }
  }
  * { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    margin: 0;
    background: var(--papel);
    color: var(--tinta);
    font-family: var(--fuente);
    font-size: 16px;
    line-height: 1.45;
  }
  main {
    max-width: 480px;
    margin: 0 auto;
    padding: 16px 16px calc(88px + env(safe-area-inset-bottom));
  }
  h1 { font-size: 22px; font-weight: 800; letter-spacing: -0.02em; margin: 8px 0 12px; }
  h2 { font-size: 15px; font-weight: 700; margin: 20px 0 8px; }

  /* etiqueta pequeña estilo pizarra de gimnasio */
  .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--tinta-suave);
  }

  .carta {
    background: var(--carta);
    border: 1px solid var(--borde);
    border-radius: var(--radio);
    padding: 14px;
    margin: 10px 0;
  }
  /* franja por tipo de sesión (color del disco) */
  .carta.tipo-fuerza { border-left: 4px solid var(--fuerza); }
  .carta.tipo-cardio { border-left: 4px solid var(--cardio); }
  .carta.tipo-elongacion { border-left: 4px solid var(--elongacion); }

  button, .boton {
    font: inherit;
    /* 44px es el piso para que un dedo acierte sin apuntar. */
    min-height: 44px;
    border: 1px solid var(--borde);
    background: var(--carta);
    color: var(--tinta);
    border-radius: 12px;
    padding: 12px 16px;
    font-weight: 700;
    cursor: pointer;
    touch-action: manipulation;
  }
  button:focus-visible, a:focus-visible, input:focus-visible, select:focus-visible {
    outline: 3px solid var(--accion);
    outline-offset: 2px;
  }
  .boton-principal {
    display: block;
    width: 100%;
    background: var(--accion);
    color: var(--accion-tinta);
    border: none;
    font-size: 18px;
    font-weight: 800;
    padding: 16px;
    border-radius: var(--radio);
  }
  .boton-secundario { width: 100%; margin-top: 8px; }
  .boton-silencioso {
    background: none;
    border: none;
    color: var(--tinta-suave);
    font-weight: 600;
    padding: 8px;
  }

  input[type='number'], input[type='text'], input[type='date'], select, textarea {
    font: inherit;
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--borde);
    border-radius: 10px;
    background: var(--carta);
    color: var(--tinta);
  }
  label { display: block; font-weight: 600; font-size: 14px; margin: 12px 0 4px; }
  .ayuda { font-size: 13px; color: var(--tinta-suave); margin: 2px 0 0; }

  /* chips seleccionables (equipamiento, filtros, RPE) */
  .chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    border: 1px solid var(--borde);
    background: var(--carta);
    color: var(--tinta);
    border-radius: 999px;
    padding: 8px 14px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }
  .chip[aria-pressed='true'] {
    background: var(--tinta);
    color: var(--papel);
    border-color: var(--tinta);
  }

  /* Barra inferior: cada pestaña es un blanco de 56px de alto y 1/5 del ancho.
     Antes el área tocable eran ~33px de alto (texto de 12px + padding), por
     debajo del mínimo de 48px que necesita un dedo. */
  .tabs {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    gap: 2px;
    background: var(--carta);
    border-top: 1px solid var(--borde);
    padding: 5px 5px calc(5px + env(safe-area-inset-bottom));
  }
  .tab {
    flex: 1;
    min-width: 0;
    min-height: 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    padding: 6px 2px;
    border-radius: 12px;
    text-decoration: none;
    color: var(--tinta-suave);
    font-size: 13px;
    font-weight: 700;
    -webkit-tap-highlight-color: transparent;
  }
  .tab svg { width: 24px; height: 24px; flex: none; }
  .tab span { line-height: 1.1; }
  .tab.activa {
    color: var(--tinta);
    background: color-mix(in srgb, var(--accion) 22%, transparent);
  }
  .tab.activa svg { color: color-mix(in srgb, var(--accion) 80%, var(--tinta)); }
  .tab:active { background: color-mix(in srgb, var(--tinta) 8%, transparent); }

  .aviso {
    background: color-mix(in srgb, var(--accion) 18%, var(--carta));
    border: 1px solid color-mix(in srgb, var(--accion) 45%, var(--borde));
    border-radius: var(--radio);
    padding: 12px 14px;
    margin: 10px 0;
    font-size: 14px;
  }
  .error { color: var(--peligro); font-size: 14px; }

  /* Buscador de ejercicios y opciones elegibles (wizard, rutina). */
  .buscador input[type='search'] {
    font: inherit;
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--borde);
    border-radius: 10px;
    background: var(--carta);
    color: var(--tinta);
    margin-top: 4px;
  }
  .opcion-ej {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    text-align: left;
    width: 100%;
    padding: 12px;
    margin-top: 8px;
  }

  /* Aviso de versión nueva: sobre las tabs, sin tapar contenido. */
  #aviso-version {
    position: fixed;
    left: 8px;
    right: 8px;
    bottom: calc(80px + env(safe-area-inset-bottom));
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--tinta);
    color: var(--papel);
    border-radius: var(--radio);
    padding: 10px 12px;
    font-size: 14px;
    font-weight: 600;
    box-shadow: 0 6px 20px rgb(0 0 0 / 25%);
  }
  #aviso-version span { flex: 1; }
  #aviso-version button {
    background: var(--accion);
    color: var(--accion-tinta);
    border: none;
    padding: 8px 14px;
    font-size: 14px;
  }
  #aviso-version .cerrar {
    background: none;
    color: var(--papel);
    padding: 8px 6px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .pop { animation: pop 0.25s ease-out; }
    @keyframes pop {
      0% { transform: scale(0.7); }
      70% { transform: scale(1.12); }
      100% { transform: scale(1); }
    }
  }
</style>
